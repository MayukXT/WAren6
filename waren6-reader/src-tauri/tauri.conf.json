{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WAren6 Reader",
  "version": "1.7.0",
  "identifier": "com.mayukxt.waren6.reader",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WAren6 Reader",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; media-src 'self' asset: https://asset.localhost data: blob:; connect-src 'self' https://github.com https://api.github.com https://raw.githubusercontent.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFRkNDREVBN0FERUMzMDUKUldRRnc5NTY2czM4anVuZWUrUXZuSGNXbWpMaVNMK1pVV0g4RjBJb2ZFZ3ZWMXE3azVYeUxydUYK",
      "endpoints": [
        "https://raw.githubusercontent.com/MayukXT/WAren6/reader-latest/latest.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
